---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Submit a 404">
  <Header />

  <main class="main">
    <div class="submit-container">
      <header class="submit-header">
        <h1 class="submit-title">Submit a 404</h1>
        <p class="submit-description">
          Found a beautifully designed 404 page? Share it with the museum.
          Submissions are reviewed before being published.
        </p>
      </header>

      <form
        class="submit-form"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        enctype="multipart/form-data"
      >
        <div class="form-group">
          <label for="url404" class="form-label">URL that 404'd *</label>
          <input
            type="url"
            id="url404"
            name="url404"
            class="form-input"
            placeholder="https://example.com/page-that-does-not-exist"
            required
          />
        </div>

        <div class="form-group">
          <label for="websiteUrl" class="form-label">Website URL *</label>
          <input
            type="url"
            id="websiteUrl"
            name="websiteUrl"
            class="form-input"
            placeholder="https://example.com"
            required
          />
          <span class="form-hint">The main website URL (not the 404 page)</span>
        </div>

        <div class="form-group">
          <label for="screenshot" class="form-label">Screenshot</label>
          <input
            type="file"
            id="screenshot"
            name="screenshot"
            class="form-input"
            accept="image/*"
          />
          <span class="form-hint">Upload an image of the 404 page (optional if you provide the URL above)</span>
        </div>

        <div class="form-group">
          <label for="websiteName" class="form-label">Website Name *</label>
          <input
            type="text"
            id="websiteName"
            name="websiteName"
            class="form-input"
            placeholder="Stripe, GitHub, etc."
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label">Tags</label>
          <div class="tag-select">
            {['saas', 'minimal', 'illustration', 'space', 'cute', 'fun', 'glitch', 'playful', 'brand', 'gaming', 'travel', 'email', 'productivity', 'design', 'crowdfunding', 'entertainment'].map(tag => (
              <label class="tag-checkbox">
                <input type="checkbox" name="tags" value={tag} />
                <span>{tag}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="form-group">
          <label for="submitter" class="form-label">Your Name *</label>
          <input
            type="text"
            id="submitter"
            name="submitter"
            class="form-input"
            placeholder="Anonymous or your handle"
            required
          />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-submit">Submit to Museum</button>
        </div>
      </form>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    flex: 1;
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-3);
    width: 100%;
  }

  .submit-container {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }

  .submit-header {
    text-align: center;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(245, 240, 232, 0.1);
  }

  .submit-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .submit-description {
    color: var(--color-text-muted);
    font-size: 14px;
    margin: 0;
  }

  .form-group {
    margin-bottom: var(--space-4);
  }

  .form-label {
    display: block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .form-input {
    width: 100%;
  }

  .form-hint {
    display: block;
    font-size: 11px;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .tag-select {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    cursor: pointer;
  }

  .tag-checkbox input {
    accent-color: var(--color-accent);
  }

  .tag-checkbox span {
    font-size: 12px;
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .tag-checkbox:hover span {
    background: var(--color-bg-card-hover);
    color: var(--color-text);
  }

  .form-actions {
    padding-top: var(--space-4);
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .btn-submit {
    width: 100%;
    justify-content: center;
    padding: var(--space-3);
    font-size: 14px;
  }
</style>