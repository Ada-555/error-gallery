---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import exhibits from '../../data/exhibits.json';

export async function getStaticPaths() {
  return exhibits.map(exhibit => ({
    params: { id: exhibit.id },
    props: { exhibit },
  }));
}

const { exhibit } = Astro.props;

const relatedExhibits = exhibits
  .filter(e => e.id !== exhibit.id && e.tags.some(t => exhibit.tags.includes(t)))
  .slice(0, 3);
---

<BaseLayout title={exhibit.website}>
  <Header />

  <main class="main">
    <div class="exhibit-container">
      <div class="exhibit-image">
        <img src={exhibit.screenshot} alt={`${exhibit.website} 404 page`} />
      </div>

      <aside class="exhibit-meta">
        <div class="meta-header">
          <h1 class="meta-title">{exhibit.website}</h1>
          <span class="meta-upvotes">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 19V5M5 12l7-7 7 7"/>
            </svg>
            {exhibit.upvotes} upvotes
          </span>
        </div>

        <div class="meta-section">
          <h3>Tags</h3>
          <div class="meta-tags">
            {exhibit.tags.map(tag => (
              <a href={`/error-gallery/?tag=${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        </div>

        <div class="meta-section">
          <h3>Submitted From</h3>
          <a href={exhibit.submittedFrom} target="_blank" rel="noopener" class="meta-link">
            {exhibit.submittedFrom}
          </a>
        </div>

        <div class="meta-section">
          <h3>Website</h3>
          <a href={exhibit.websiteUrl} target="_blank" rel="noopener" class="meta-link">
            {exhibit.websiteUrl}
          </a>
        </div>

        <div class="meta-section">
          <h3>Submitted By</h3>
          <span class="meta-submitter">{exhibit.submitter}</span>
        </div>

        <div class="meta-section">
          <h3>Date Added</h3>
          <span class="meta-date">{exhibit.dateAdded}</span>
        </div>

        <div class="meta-actions">
          <a href={exhibit.submittedFrom} target="_blank" rel="noopener" class="btn">
            View Original
          </a>
          <a href={`/error-gallery/?tag=${exhibit.tags[0]}`} class="btn btn-secondary">
            Related Exhibits
          </a>
        </div>
      </aside>
    </div>

    {relatedExhibits.length > 0 && (
      <section class="related-section">
        <h2 class="related-title">You might also like</h2>
        <div class="related-grid">
          {relatedExhibits.map(e => (
            <GalleryCard {...e} />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    flex: 1;
    padding: var(--space-4) 0;
  }

  .exhibit-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-3);
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-4);
    align-items: start;
  }

  .exhibit-image {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .exhibit-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .exhibit-meta {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid rgba(245, 240, 232, 0.1);
  }

  .meta-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .meta-upvotes {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-accent);
    font-size: 14px;
    flex-shrink: 0;
  }

  .meta-section h3 {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-1) 0;
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .meta-link {
    color: var(--color-accent-purple);
    word-break: break-all;
    font-size: 13px;
  }

  .meta-submitter {
    color: var(--color-text);
    font-size: 13px;
  }

  .meta-date {
    color: var(--color-text-muted);
    font-size: 13px;
  }

  .meta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(245, 240, 232, 0.1);
    margin-top: var(--space-2);
  }

  .meta-actions .btn {
    justify-content: center;
    text-align: center;
  }

  .related-section {
    max-width: 1200px;
    margin: var(--space-5) auto 0;
    padding: 0 var(--space-3);
  }

  .related-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .exhibit-container {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>