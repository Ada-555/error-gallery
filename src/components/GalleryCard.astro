---
export interface Props {
  id: string;
  website: string;
  websiteUrl: string;
  screenshot: string;
  tags: string[];
  submitter: string;
  dateAdded: string;
  upvotes: number;
}

const { id, website, websiteUrl, screenshot, tags, submitter, dateAdded, upvotes } = Astro.props;
---

<a href={`/error-gallery/exhibit/${id}`} class="gallery-card">
  <div class="card-image">
    <img src={screenshot} alt={`${website} 404 page`} loading="lazy" />
    <div class="card-overlay">
      <span class="view-btn">View Exhibit</span>
    </div>
  </div>
  <div class="card-meta">
    <div class="card-header">
      <h3 class="card-title">{website}</h3>
      <span class="card-upvotes">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
        {upvotes}
      </span>
    </div>
    <div class="card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <div class="card-footer">
      <span class="card-submitter">by {submitter}</span>
      <span class="card-date">{dateAdded}</span>
    </div>
  </div>
</a>

<style>
  .gallery-card {
    display: block;
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .gallery-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(201, 168, 76, 0.15);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--color-bg);
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .gallery-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 10, 0.9) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--space-3);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .gallery-card:hover .card-overlay {
    opacity: 1;
  }

  .view-btn {
    background: var(--color-accent);
    color: var(--color-bg);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: 12px;
    font-weight: 600;
  }

  .card-meta {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .card-upvotes {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--color-accent);
    font-size: 12px;
    flex-shrink: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .card-submitter {
    color: var(--color-accent-purple);
  }
</style>