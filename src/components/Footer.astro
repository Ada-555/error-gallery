---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">404 Museum</span>
      <p class="footer-tagline">The internet's best 404 pages, preserved and celebrated.</p>
    </div>

    <nav class="footer-nav">
      <a href="/">Gallery</a>
      <a href="/submit">Submit</a>
      <a href="/about">About</a>
      <a href="/search">Search</a>
    </nav>

    <p class="footer-credits">
      &copy; {currentYear} 404 Museum. Curated with care.
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
    padding: var(--space-5) 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-3);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .footer-tagline {
    color: var(--color-text-muted);
    font-size: 13px;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    gap: var(--space-4);
  }

  .footer-nav a {
    color: var(--color-text-muted);
    font-size: 13px;
    transition: color var(--transition-fast);
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  .footer-credits {
    color: var(--color-text-muted);
    font-size: 11px;
    margin: 0;
  }
</style>